      "ledmatrix_min_version": "2.0.0"
    },
    {
      "version": "1.5.0",
      "released": "2026-04-01",
      "ledmatrix_min_version": "2.0.0"
    }
  ],
  "assets": {
    "uses_core_assets": true,
    "pga_logos": "assets/sports/pga_logos/"
  },
