{
  "id": "youtube-stats",
  "name": "YouTube Stats",
  "version": "1.0.2",
  "author": "ChuckBuilds",
  "description": "Display YouTube channel statistics including subscriber count, total views, and channel name on your LED matrix",
  "category": "social",
  "tags": [
    "youtube",
    "social",
    "stats",
    "display",
    "channel"
  ],
  "display_modes": [
    "youtube_stats"
  ],
  "entry_point": "manager.py",
  "class_name": "YouTubeStatsPlugin",
  "update_interval": 300,
  "default_duration": 15,
  "requires": {
    "python": ">=3.9"
  },
  "config_schema": "config_schema.json",
  "api_requirements": [
    {
      "name": "YouTube Data API v3",
      "required": true,
      "description": "YouTube Data API for fetching channel statistics",
      "url": "https://developers.google.com/youtube/v3",
      "rate_limit": "10,000 units per day (default quota)"
    }
  ],
  "versions": [
    {
      "released": "2026-05-15",
      "version": "1.0.2",
      "ledmatrix_min": "2.0.0"
    },
    {
      "version": "1.0.1",
      "released": "2026-04-07",
      "ledmatrix_min": "2.0.0"
    }
  ],
  "last_updated": "2026-05-15",
  "compatible_versions": [
    ">=2.0.0"
  ]
}
