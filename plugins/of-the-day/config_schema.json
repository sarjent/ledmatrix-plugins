{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "x-propertyOrder": [
    "enabled",
    "update_interval",
    "display_rotate_interval",
    "subtitle_rotate_interval",
    "category_order",
    "file_manager",
    "categories",
    "display_duration"
  ],
  "properties": {
    "enabled": {
      "type": "boolean",
      "default": false,
      "description": "Enable or disable the of-the-day plugin"
    },
    "update_interval": {
      "type": "integer",
      "default": 3600,
      "minimum": 60,
      "description": "Update interval in seconds (checks for new day)"
    },
    "display_rotate_interval": {
      "type": "number",
      "default": 20,
      "minimum": 5,
      "description": "Seconds between rotating different display elements (title/definition/example)"
    },
    "subtitle_rotate_interval": {
      "type": "number",
      "default": 10,
      "minimum": 5,
      "description": "Seconds between rotating subtitle information"
    },
    "category_order": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": ["word_of_the_day", "slovenian_word_of_the_day"],
      "description": "Order to display categories"
    },
    "categories": {
      "type": "object",
      "title": "Categories",
      "description": "Category configurations. Each key is a category ID (e.g., word_of_the_day). Categories are added/removed via the file manager.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable or disable this category"
          },
          "data_file": {
            "type": "string",
            "description": "Path to data file (relative to plugin directory)"
          },
          "display_name": {
            "type": "string",
            "description": "Display name shown in configuration"
          }
        },
        "required": ["enabled", "data_file", "display_name"]
      }
    },
    "display_duration": {
      "type": "number",
      "default": 40,
      "minimum": 10,
      "description": "How long to display each category in seconds"
    },
    "file_manager": {
      "type": "null",
      "title": "Data Files",
      "description": "Manage your Of The Day JSON data files",
      "x-widget": "plugin-file-manager",
      "x-widget-config": {
        "actions": {
          "list":   "list-files",
          "get":    "get-file",
          "save":   "save-file",
          "upload": "upload-file",
          "delete": "delete-file",
          "create": "create-file",
          "toggle": "toggle-category"
        },
        "upload_hint":    "JSON files with day numbers 1–365 as keys",
        "directory_label": "of_the_day/",
        "create_fields": [
          {
            "key":         "category_name",
            "label":       "Category Name",
            "placeholder": "e.g., my_words",
            "pattern":     "^[a-z0-9_]+$",
            "hint":        "Lowercase letters, numbers, underscores — used as filename"
          },
          {
            "key":         "display_name",
            "label":       "Display Name",
            "placeholder": "e.g., My Words",
            "hint":        "Shown in plugin configuration (leave blank to auto-generate)"
          }
        ],
        "toggle_key": "category_name"
      }
    }
  },
  "required": ["enabled"]
}

